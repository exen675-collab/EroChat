{
    "name": "erochat",
    "version": "1.0.0",
    "private": true,
    "description": "EroChat with simple username/password auth",
    "main": "dist/server.js",
    "scripts": {
        "build": "npm run build:server && npm run build:client",
        "build:client": "vite build",
        "build:server": "tsc -p tsconfig.server.json",
        "dev": "vite",
        "dev:client": "vite",
        "typecheck": "tsc -p tsconfig.test.json --noEmit",
        "start": "node dist/server.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "connect-sqlite3": "^0.9.15",
        "express": "^4.21.2",
        "express-session": "^1.18.1",
        "multer": "^2.1.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "sqlite3": "^5.1.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/connect-sqlite3": "^0.9.6",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/jsdom": "^28.0.1",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "jsdom": "^29.0.0",
        "postcss": "^8.5.14",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.10",
        "vitest": "^4.1.0"
    }
}
