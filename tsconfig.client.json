{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "rootDir": "src/client",
        "outDir": "dist/client",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": ["src/client/**/*.ts", "src/client/**/*.tsx"]
}
